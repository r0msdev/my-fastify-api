# MikroORM connection string — used by the API and the MikroORM CLI
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb"

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=johndoe
POSTGRES_PASSWORD=randompassword
POSTGRES_DB=mydb

# pgAdmin
PGADMIN_DEFAULT_EMAIL=johndoe@local.com
PGADMIN_DEFAULT_PASSWORD=randompassword