FROM node:22-alpine

WORKDIR /app

# Copy everything first so prisma/schema.prisma is available for prisma generate
COPY . .

# Install dependencies (postinstall runs prisma generate, schema is now present)
ENV DATABASE_URL=postgresql://placeholder:placeholder@localhost:5432/placeholder
RUN npm install

EXPOSE 3000

# Run migrations then start with hot-reload
CMD ["sh", "-c", "npm run db:migrate:deploy && npm run dev"]
