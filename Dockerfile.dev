FROM node:22-alpine

WORKDIR /app

# Layer cache: install deps first, source files later
COPY package*.json ./
RUN npm ci --ignore-scripts

# Copy source (overridden by volume mount in dev)
COPY . .

EXPOSE 3000

# Generate client, deploy migrations, then start with hot-reload
CMD ["sh", "-c", "npx prisma generate && npm run db:migrate:deploy && npm run dev"]
