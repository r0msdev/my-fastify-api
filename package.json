{
  "name": "my-fastify-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:migrate": "node --env-file=.env node_modules/.bin/mikro-orm migration:create",
    "db:migrate:up": "node --env-file=.env node_modules/.bin/mikro-orm migration:up",
    "db:migrate:fresh": "node --env-file=.env node_modules/.bin/mikro-orm schema:fresh --run",
    "db:schema:update": "node --env-file=.env node_modules/.bin/mikro-orm schema:update --run",
    "db:schema:check": "node --env-file=.env node_modules/.bin/mikro-orm schema:check"
  },
  "dependencies": {
    "@fastify/env": "^5.0.3",
    "@fastify/sensible": "^6.0.4",
    "@mikro-orm/core": "^6.6.8",
    "@mikro-orm/migrations": "^6.6.8",
    "@mikro-orm/postgresql": "^6.6.8",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.6.8",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
