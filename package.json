{
  "name": "my-fastify-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:migrate": "mikro-orm migration:create",
    "db:migrate:up": "mikro-orm migration:up",
    "db:migrate:fresh": "mikro-orm schema:fresh --run",
    "db:schema:update": "mikro-orm schema:update --run",
    "db:schema:check": "mikro-orm schema:check"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@mikro-orm/core": "^6.6.8",
    "@mikro-orm/migrations": "^6.6.8",
    "@mikro-orm/postgresql": "^6.6.8",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.6.8",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1"
  }
}
